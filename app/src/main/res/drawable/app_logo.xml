    <path
        android:fillColor="#00000000"
        android:pathData="M125,70 C130,78 108,55 100,55"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="7"
        android:strokeLineCap="round" />

    <!-- Garment body -->
    <path
        android:fillColor="#00000000"
        android:pathData="M60,70 C55,85 52,115 55,145 L145,145 C148,115 145,85 140,70"
        android:strokeColor="#E8A598"
        android:strokeWidth="6"
        android:strokeLineCap="round"
