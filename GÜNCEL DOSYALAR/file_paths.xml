<?xml version="1.0" encoding="utf-8"?>
<paths>
    <!--
        ÖNEMLI: cache-path root eklendi.
        Kamera fotoğrafları (camera_image_*.jpg) ve .kmb dosyaları
        cacheDir root'unda oluşturuluyor. Bu satır olmadan FileProvider
        SecurityException fırlatır.
    -->
    <cache-path name="cache_root" path="." />

    <!--  Önceki kod uyumluluğu için images/ alt klasörü  -->
    <cache-path name="shared_images" path="images/" />

    <!--  External app dosyaları (gerekirse)  -->
    <external-files-path name="external_files" path="." />
</paths>
